---
import Layout from '../layouts/Layout.astro';
import HaircutCounter from '../components/haircut/HaircutCounter';
import LeagueTable from '../components/premier-league/LeagueTable';
import ManchesterMatches from '../components/premier-league/ManchesterMatches';
import HistoricalStats from '../components/premier-league/HistoricalStats';
import MatchPredictor from '../components/predictor/MatchPredictor';
---

<Layout title="5 Games in a Row | Manchester United Haircut Challenge">
  <div class="container">
    <section class="hero">
      <h1>5 Games in a Row</h1>
      <p class="hero-subtitle">Tracking Frank's haircut journey since October 2024</p>
      <div class="hero-badge">
        <span>🎯 Target: 5 consecutive wins</span>
      </div>
    </section>

    <section class="main-grid">
      <div class="grid-item counter-section">
        <HaircutCounter client:load />
      </div>
      
      <div class="grid-item predictor-section">
        <MatchPredictor client:load />
      </div>
      
      <div class="standings-container">
        <div class="grid-item matches-section">
          <ManchesterMatches client:load />
        </div>
        
        <div class="grid-item standings-section">
          <LeagueTable client:load />
        </div>
      </div>
      
      <div class="grid-item stats-section">
        <HistoricalStats client:load />
      </div>
    </section>

    <section class="about">
      <h2>What's This About?</h2>
      <div class="about-content">
        <p>
          In October 2024, Manchester United fan Frank Ilett (@TheUnitedStrand) made a promise: 
          he wouldn't cut his hair until the Red Devils won 5 games in a row.
        </p>
        <p>
          Months later, he's still waiting. The challenge has become a viral sensation, 
          with thousands of fans following his journey on social media.
        </p>
        <p class="hashtag">#TheUnitedStrand #5GamesInARow</p>
      </div>
    </section>
  </div>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    background: linear-gradient(135deg, 
      var(--color-red) 0%, 
      var(--color-red-dark) 50%,
      #8B0000 100%
    );
    border-radius: var(--radius-2xl);
    margin-bottom: var(--space-2xl);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    animation: heroFadeIn 0.8s ease forwards;
  }

  @keyframes heroFadeIn {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.6;
    animation: patternMove 20s linear infinite;
  }

  @keyframes patternMove {
    from {
      background-position: 0 0;
    }
    to {
      background-position: 60px 60px;
    }
  }

  .hero h1 {
    font-size: 4.5rem;
    color: var(--color-white);
    margin-bottom: var(--space-md);
    position: relative;
    text-shadow: 3px 3px 6px rgba(0, 0, 0, 0.4);
    letter-spacing: 0.02em;
    animation: titleBounce 0.8s ease 0.2s forwards;
    opacity: 0;
  }

  @keyframes titleBounce {
    0% {
      opacity: 0;
      transform: translateY(-20px) scale(0.9);
    }
    60% {
      transform: translateY(5px) scale(1.02);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .hero-subtitle {
    font-size: 1.35rem;
    color: rgba(255, 255, 255, 0.92);
    margin-bottom: var(--space-xl);
    position: relative;
    font-weight: 500;
    animation: fadeInUp 0.6s ease 0.4s forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-badge {
    position: relative;
    display: inline-block;
    animation: fadeInUp 0.6s ease 0.6s forwards;
    opacity: 0;
  }

  .hero-badge span {
    background: var(--color-gold);
    color: var(--color-black);
    padding: var(--space-md) var(--space-2xl);
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    box-shadow: 0 6px 20px rgba(251, 225, 34, 0.5);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: inline-block;
    animation: badgePulse 2s ease-in-out 1s infinite;
  }

  @keyframes badgePulse {
    0%, 100% {
      box-shadow: 0 6px 20px rgba(251, 225, 34, 0.5);
    }
    50% {
      box-shadow: 0 10px 40px rgba(251, 225, 34, 0.8);
    }
  }

  .hero-badge span:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 15px 40px rgba(251, 225, 34, 0.7);
  }

  .main-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .grid-item {
    min-width: 0;
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  .grid-item:nth-child(1) { animation-delay: 0.1s; }
  .grid-item:nth-child(2) { animation-delay: 0.2s; }
  .grid-item:nth-child(3) { animation-delay: 0.3s; }
  .grid-item:nth-child(4) { animation-delay: 0.4s; }
  .grid-item:nth-child(5) { animation-delay: 0.5s; }

  .standings-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    height: 620px;
    grid-column: 1 / -1;
  }

  .standings-container .grid-item {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .standings-container .matches-section {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .standings-container .standings-section {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .counter-section {
    grid-column: 1 / -1;
    max-width: 500px;
    margin: 0 auto;
    width: 100%;
  }

  .predictor-section {
    grid-column: 1 / -1;
    max-width: 500px;
    margin: 0 auto;
    width: 100%;
  }

  .stats-section {
    grid-column: 1 / -1;
  }

  .about {
    background: var(--color-white);
    border-radius: var(--radius-2xl);
    padding: var(--space-2xl);
    box-shadow: var(--shadow-lg);
    margin-bottom: var(--space-2xl);
    border: 1px solid var(--border-color);
    animation: fadeInUp 0.8s ease 0.8s forwards;
    opacity: 0;
    position: relative;
    overflow: hidden;
  }

  .about::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, 
      var(--color-red) 0%, 
      var(--color-gold) 50%, 
      var(--color-red) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 3s ease infinite;
  }

  .about h2 {
    color: var(--color-red);
    margin-bottom: var(--space-xl);
    text-align: center;
    font-size: 2rem;
    animation: fadeInUp 0.6s ease 1s forwards;
    opacity: 0;
  }

  .about-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .about-content p {
    margin-bottom: var(--space-lg);
    line-height: 1.9;
    font-size: 1.05rem;
    color: var(--text-secondary);
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  .about-content p:nth-child(2) {
    animation-delay: 1.1s;
  }

  .about-content p:nth-child(3) {
    animation-delay: 1.2s;
  }

  .hashtag {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-red);
    font-weight: 700;
    letter-spacing: 0.15em;
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-xl);
    background: linear-gradient(135deg, rgba(218, 41, 28, 0.08) 0%, rgba(251, 225, 34, 0.1) 100%);
    border-radius: 50px;
    display: inline-block;
    animation: fadeInUp 0.6s ease 1.3s forwards, float 3s ease-in-out 2s infinite;
    opacity: 0;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  @media (max-width: 1024px) {
    .main-grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 3rem;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-2xl) var(--space-md);
    }

    .hero h1 {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .about {
      padding: var(--space-lg);
    }
  }
</style>
