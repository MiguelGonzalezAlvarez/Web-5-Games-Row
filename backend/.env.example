# Backend Environment Variables

# App
DEBUG=true
APP_NAME="5 Games in a Row API"
APP_VERSION="1.0.0"

# Database
DATABASE_URL=sqlite:///./5gamesrow.db
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname

# Football APIs (get your free keys at their websites)

# football-data.org - Get free key at https://football-data.org
FOOTBALL_API_KEY=your_football_data_api_key
FOOTBALL_DATA_PROVIDER=api-football  # Options: api-football, openfootball, thesportsdb, demo

# api-football.com - Get free key at https://www.api-football.com (100 requests/day free)
API_FOOTBALL_KEY=your_api_football_key

# OpenFootball - No API key needed (GitHub-based data)
# Just set provider to "openfootball" in FOOTBALL_DATA_PROVIDER

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# Redis (optional - for caching in production)
# REDIS_URL=redis://localhost:6379

# Supabase (optional - for auth/database)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-anon-key
# SUPABASE_JWT_SECRET=your-jwt-secret

# Frontend URL (for CORS)
# FRONTEND_URL=http://localhost:4321

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
