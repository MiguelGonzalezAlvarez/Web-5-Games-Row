import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The Manchester United 5 Games in a Row Challenge Tracker' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#DA291C" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-content">
        <a href="/" class="logo">
          <span class="logo-number">5</span>
          <span class="logo-text">Games in a Row</span>
        </a>
        <nav class="main-nav">
          <a href="/">Home</a>
          <a href="/standings">Standings</a>
          <a href="/simulator">Simulator</a>
          <a href="/community">Community</a>
        </nav>
      </div>
    </header>
    
    <main>
      <slot />
    </main>
    
    <footer class="site-footer">
      <div class="container">
        <p>Not affiliated with Manchester United FC. Just a fan tracking the haircut challenge.</p>
        <p class="footer-tagline">#TheUnitedStrand #5GamesInARow</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: var(--color-red);
    padding: var(--space-md) 0;
    box-shadow: var(--shadow-md);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .logo:hover {
    color: var(--color-white);
  }

  .logo-number {
    background: var(--color-white);
    color: var(--color-red);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    font-size: 1.25rem;
  }

  .main-nav {
    display: flex;
    gap: var(--space-lg);
  }

  .main-nav a {
    color: var(--color-white);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .main-nav a:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-white);
  }

  main {
    min-height: calc(100vh - 200px);
    padding: var(--space-xl) 0;
  }

  .site-footer {
    background: var(--color-black);
    color: var(--color-gray-400);
    padding: var(--space-xl) 0;
    text-align: center;
  }

  .site-footer p {
    margin-bottom: var(--space-sm);
    font-size: 0.875rem;
  }

  .footer-tagline {
    color: var(--color-red);
    font-weight: 600;
    font-family: var(--font-display);
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .header-content {
      flex-direction: column;
      text-align: center;
    }

    .main-nav {
      gap: var(--space-sm);
      flex-wrap: wrap;
      justify-content: center;
    }

    .main-nav a {
      font-size: 0.75rem;
      padding: var(--space-xs) var(--space-sm);
    }
  }
</style>
